{
  "name": "ai-aggregation-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "AI 聚合网站 Monorepo",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "pnpm --filter @repo/db generate",
    "db:migrate": "pnpm --filter @repo/db migrate",
    "db:seed": "pnpm --filter @repo/db seed",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0"
  }
}
