generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            ChatSession[]
  tasks               Task[]
  usage               UserUsage[]
  voiceTranscriptions VoiceTranscription[]
  chatHistory         ChatHistory[]        @relation("ChatHistoryToUser")
  imageHistory        ImageHistory[]       @relation("ImageHistoryToUser")
  voiceHistory        VoiceHistory[]       @relation("VoiceHistoryToUser")

  @@map("users")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("chat_sessions")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("messages")
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  type        String
  status      String    @default("pending")
  input       Json
  output      Json?
  error       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("tasks")
}

model UserUsage {
  id        String   @id @default(cuid())
  userId    String
  tokens    Int      @default(0)
  tasks     Int      @default(0)
  period    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([userId])
  @@map("user_usage")
}

model VoiceTranscription {
  id            String    @id @default(cuid())
  userId        String
  fileName      String
  fileSize      Int
  duration      Int?
  format        String
  model         String    @default("FunAudioLLM/SenseVoiceSmall")
  status        String    @default("pending")
  transcription String?   @db.Text
  error         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("voice_transcriptions")
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String
  title     String
  preview   String   @db.Text
  model     String
  provider  String
  messages  Json
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, name: "ChatHistoryToUser")

  @@index([userId])
  @@index([createdAt])
  @@map("chat_history")
}

model ImageHistory {
  id            String   @id @default(cuid())
  userId        String
  title         String?
  prompt        String   @db.Text
  negativePrompt String?  @db.Text
  model         String
  style         String?
  aspectRatio   String?
  imageUrl      String
  parameters    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, name: "ImageHistoryToUser")

  @@index([userId])
  @@index([createdAt])
  @@map("image_history")
}

model VoiceHistory {
  id            String   @id @default(cuid())
  userId        String
  title         String
  preview       String   @db.Text
  model         String
  duration      String
  fileName      String
  fileSize      Int
  transcription String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, name: "VoiceHistoryToUser")

  @@index([userId])
  @@index([createdAt])
  @@map("voice_history")
}
