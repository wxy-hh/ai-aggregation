generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String?
  name          String?
  passwordHash  String?
  role          String   @default("user")   // "user" | "admin"
  status        String   @default("active") // "active" | "disabled"
  tokens        Int      @default(20000)    // AI 调用配额
  emailVerified DateTime?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions            ChatSession[]
  tasks               Task[]
  aiUsageRecords      AIUsageRecord[]
  voiceTranscriptions VoiceTranscription[]
  chatHistory         ChatHistory[]        @relation("ChatHistoryToUser")
  imageHistory        ImageHistory[]       @relation("ImageHistoryToUser")
  voiceHistory        VoiceHistory[]       @relation("VoiceHistoryToUser")
  oauthAccounts       OAuthAccount[]
  refreshTokens       RefreshToken[]

  @@map("users")
}

model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("chat_sessions")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("messages")
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  type        String
  status      String    @default("pending")
  input       Json
  output      Json?
  error       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("tasks")
}

model AIUsageRecord {
  id              String   @id @default(cuid())
  userId          String
  feature         String
  action          String
  provider        String?
  model           String?
  endpoint        String?
  requestId       String?
  inputTokens     Int?
  outputTokens    Int?
  totalTokens     Int?
  cachedTokens    Int?
  reasoningTokens Int?
  taskCount       Int      @default(1)
  status          String   @default("success")
  rawUsage        Json?
  metadata        Json?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, feature, createdAt])
  @@index([provider, model])
  @@map("ai_usage_records")
}

model VoiceTranscription {
  id            String    @id @default(cuid())
  userId        String
  fileName      String
  fileSize      Int
  duration      Int?
  format        String
  model         String    @default("FunAudioLLM/SenseVoiceSmall")
  status        String    @default("pending")
  transcription String?   @db.Text
  error         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("voice_transcriptions")
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String
  title     String
  preview   String   @db.Text
  model     String
  provider  String
  messages  Json
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, name: "ChatHistoryToUser")

  @@index([userId])
  @@index([createdAt])
  @@map("chat_history")
}

model ImageHistory {
  id            String   @id @default(cuid())
  userId        String
  title         String?
  prompt        String   @db.Text
  negativePrompt String?  @db.Text
  model         String
  style         String?
  aspectRatio   String?
  imageUrl      String
  parameters    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, name: "ImageHistoryToUser")

  @@index([userId])
  @@index([createdAt])
  @@map("image_history")
}

model VoiceHistory {
  id            String   @id @default(cuid())
  userId        String
  title         String
  preview       String   @db.Text
  model         String
  duration      String
  fileName      String
  fileSize      Int
  transcription String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, name: "VoiceHistoryToUser")

  @@index([userId])
  @@index([createdAt])
  @@map("voice_history")
}
