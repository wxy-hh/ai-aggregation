# ============================================
# 数据库配置
# ============================================
# PostgreSQL 连接字符串
# 本地开发: postgresql://user:password@localhost:5432/ai_aggregation
# Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Neon: postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]
DATABASE_URL="postgresql://user:password@localhost:5432/ai_aggregation"

# ============================================
# Redis 配置（用于 BullMQ 队列）
# ============================================
# 本地开发
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# Upstash Redis（推荐用于生产环境）
# REDIS_HOST="your-redis.upstash.io"
# REDIS_PORT="6379"
# REDIS_PASSWORD="your-redis-password"

# ============================================
# 对象存储配置（可选）
# ============================================
# MinIO（本地开发）
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="ai-aggregation"

# 阿里云 OSS（生产环境）
# OSS_ACCESS_KEY_ID="your-access-key-id"
# OSS_ACCESS_KEY_SECRET="your-access-key-secret"
# OSS_BUCKET="your-bucket-name"
# OSS_REGION="oss-cn-hangzhou"

# ============================================
# AI 服务商 API Keys
# ============================================

# 通义千问（DashScope）
DASHSCOPE_API_KEY="sk-your-dashscope-api-key"

# 智谱 GLM
ZHIPU_API_KEY="your-zhipu-api-key"

# DeepSeek
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# 硅基流动（Kolors 图像生成）
SILICONFLOW_API_KEY="sk-your-siliconflow-api-key"
SILICONFLOW_API_URL="https://api.siliconflow.cn/v1"
SILICONFLOW_DEFAULT_MODEL="FunAudioLLM/SenseVoiceSmall"

# 讯飞星火
XUNFEI_API_PASSWORD="your-xunfei-api-password"

# 豆包（火山方舟）
ARK_API_KEY="your-ark-api-key"
# CodingPlan 套餐专用 Base URL（重要：使用此 URL 才会消耗 CodingPlan 额度）
# 注意：必须使用 /api/coding/v3 路径，而不是 /api/v3
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/coding/v3"
ARK_MODEL="doubao-seed-2.0-lite"

# ============================================
# 应用配置
# ============================================
# Next.js 应用 URL
NEXT_PUBLIC_APP_URL="http://localhost:3030"

# 身份认证密钥（生产环境请使用强密码）
AUTH_SECRET="your-auth-secret-change-this-in-production"
NEXTAUTH_URL="http://localhost:3030"
