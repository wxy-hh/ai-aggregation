{
  "extends": "../../packages/config-typescript/base.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
